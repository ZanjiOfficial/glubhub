@page "/beskeder"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Authorization
@using ChatContracts
@attribute [Authorize]

<PageTitle>Fiskebeskeder</PageTitle>

@if (string.IsNullOrEmpty(userEmail))
{
    <p>Henter brugeroplysninger...</p>
    <UserInfoCollectionComponent OnUserInfoSaved="OnUserInfoProvided" />
}
else
{
    <h3>Velkommen, @userEmail!</h3>
    @if (systemMessages.Count == 0)
    {
        <p>Der er ingen beskeder.</p>
    }
    else
    {
        <ul>
            @foreach (var message in systemMessages)
            {
                <li>@message</li>
            }
        </ul>
    }
}

@code {
    private readonly List<string> systemMessages = new();
    private string userEmail = string.Empty;
    private string? userID;
    private HubConnection? hubConnection;

    // No auth-state logic here; all user info comes from DbContext via the child component
    private async Task OnUserInfoProvided(ConnectedUser info)
    {
        userID = info.UserId;
        userEmail = info.Email;

        if (!string.IsNullOrWhiteSpace(userID) && !string.IsNullOrWhiteSpace(userEmail))
        {
            await ConnectToServer(userID, userEmail);
        }
    }

    private async Task ConnectToServer(string userId, string userName)
    {
        // Keep a reference to the connection
        hubConnection = new HubConnectionBuilder()
            .WithUrl($"https://localhost:7076/chathub?userid={userId}&username={userName}")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string>("ReceiveSystemMessage", RecieveSystemMessage);

        await hubConnection.StartAsync();
    }

    private void RecieveSystemMessage(string message)
    {
        if (!string.IsNullOrEmpty(message))
        {
            systemMessages.Add(message);
        }
    }
}