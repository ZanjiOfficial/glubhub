@using glubhub.Models
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div id="@MapId" style="width:@Width; height:@Height;"></div>

@code {
    [Parameter] public string MapId { get; set; } = "map";
    [Parameter] public string Width { get; set; } = "100%";
    [Parameter] public string Height { get; set; } = "400px";
    [Parameter] public double Latitude { get; set; } = 0;
    [Parameter] public double Longitude { get; set; } = 0;
    [Parameter] public int Zoom { get; set; } = 2;

    [Parameter] public EventCallback<(double Lat, double Lng)> OnCoordinatesSelected { get; set; }

    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", new object[] { "./leafletmap.js" });
            if (module != null)
            {
                await module.InvokeVoidAsync(
                    "load_map", MapId, Latitude, Longitude, Zoom, DotNetObjectReference.Create(this));
            }
        }
    }

    [JSInvokable]
    public async Task SetCoordinates(double lat, double lng)
    {
        await OnCoordinatesSelected.InvokeAsync((lat, lng));
    }

    public async ValueTask DisposeAsync()
    {
        if (module != null)
        {
            await module.DisposeAsync();
        }
    }
}

