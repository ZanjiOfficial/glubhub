@page "/posts"
@inject IPostRepository<Post> postRepository

<h3>Create a post</h3>

<EditForm Model="@post"
          OnValidSubmit="CreatePostAsync"
          FormName="PostForm">
    <DataAnnotationsValidator />

    <InputTextArea @bind-Value="post.Content"
                   class="form-control"
                   rows="3"
                   placeholder="What's happening?"
                   maxlength="280" />

    <ValidationMessage For="@(() => post.Content)" />

    <button type="submit" class="btn btn-primary mt-2"
            disabled="@isSubmitting">
        @(isSubmitting ? "Posting..." : "Post")
    </button>
</EditForm>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-success mt-2">@statusMessage</div>
}

<hr />
<h3>Latest posts (@posts?.Count ?? 0)</h3>

@if (posts == null)
{
    <p><em>Loading…</em></p>
}
else if (!posts.Any())
{
    <p>No posts yet.</p>
}
else
{
    @foreach (var p in posts.OrderByDescending(x => x.Timestamp))
    {
        <div class="card mb-2">
            <div class="card-body">
                <small class="text-muted">@p.Timestamp.ToString("g")</small>
                <p>@p.Content</p>
            </div>
        </div>
    }
}

@code {
    private Post post = new();
    private List<Post>? posts;
    private bool isSubmitting;
    private string statusMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadPosts();
    }

    private async Task LoadPosts()
    {
        posts = (await postRepository.GetAllAsync())?.ToList();
    }

    private async Task CreatePostAsync()
    {
        if (string.IsNullOrWhiteSpace(post.Content)) return;

        isSubmitting = true;
        statusMessage = "";
        StateHasChanged();  // ✅ Forces UI refresh immediately

        try
        {
            post.Timestamp = DateTime.UtcNow;
            await postRepository.AddAsync(post);
            await postRepository.SaveChangesAsync();

            // Add to top of list and refresh
            posts ??= new();
            posts.Insert(0, post);

            statusMessage = "Post created successfully!";  // ✅ Visual feedback
            post = new Post();  // Clear form
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();  // ✅ Forces UI refresh after completion
        }
    }
}
