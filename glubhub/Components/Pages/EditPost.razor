@page "/posts"
@inject IPostRepository<Post> postRepository

<h3>Create a post</h3>

<EditForm Model="@post" OnValidSubmit="CreatePostAsync" FormName="PostForm">
    <InputText @bind-Value="post.Content"
               class="form-control mb-1"
               placeholder="Your name" />

    <InputText @bind-Value="post.Comment"
               class="form-control mb-1"
               placeholder="Where are you?" />

    <InputTextArea @bind-Value="post.Content"
                   class="form-control"
                   rows="3"
                   placeholder="What's happening?" />

    <button type="submit"
            class="btn btn-primary mt-2"
            disabled="@isSubmitting">
        @(isSubmitting ? "Posting..." : "Post")
    </button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-info mt-2">@statusMessage</div>
}

<hr />

<h3>Latest posts</h3>

@if (posts == null)
{
    <p>Loading…</p>
}
else if (!posts.Any())
{
    <p>No posts yet.</p>
}
else
{
    @foreach (var p in posts.OrderByDescending(x => x.Timestamp))
    {
        <div class="card mb-3" style="max-width: 420px;">
            <div class="card-body">

                <div class="d-flex">
                    <div class="me-2">
                        <div class="rounded-circle bg-secondary"
                             style="width:40px;height:40px;"></div>
                    </div>

                    <div>
                        <div>
                            <strong>@p.Content</strong>
                            @if (!string.IsNullOrWhiteSpace(p.Comment))
                            {
                                <span> at @p.Location</span>
                            }
                        </div>
                        <small class="text-muted">
                            @p.Timestamp.ToString("MMMM d")
                        </small>
                    </div>
                </div>

                <div class="mt-2">
                    @p.Content
                </div>

                <div class="mt-1">
                    <a href="#">+12</a>
                </div>

                <hr class="my-2" />

                <div class="d-flex justify-content-around text-muted">
                    <button type="button" class="btn btn-link btn-sm px-0">
                        👍 Likes
                    </button>
                    <button type="button" class="btn btn-link btn-sm px-0">
                        💬 Comment
                    </button>
                    <button type="button" class="btn btn-link btn-sm px-0">
                        ↗ Share
                    </button>
                </div>

                <!-- Comment input row -->
                <div class="d-flex align-items-center mt-2">
                    <div class="me-2">
                        <div class="rounded-circle bg-secondary"
                             style="width:32px;height:32px;"></div>
                    </div>
                    <input class="form-control"
                           placeholder="Write a comment…" />
                </div>

            </div>
        </div>
    }
}

@code {
    private Post post = new();       
    private List<Post>? posts;     
    private bool isSubmitting;
    private string statusMessage = "";

    protected override async Task OnInitializedAsync()
    {
        posts = (await postRepository.GetAllAsync()).ToList();
    }

    private async Task CreatePostAsync()
    {
        // TEMP: allow any content so you can test posting
        // if (string.IsNullOrWhiteSpace(post.Content))
        // {
        //     statusMessage = "Please write something before posting.";
        //     return;
        // }

        isSubmitting = true;
        statusMessage = "";

        post.Timestamp = DateTime.UtcNow;

        await postRepository.AddAsync(post);
        await postRepository.SaveChangesAsync();

        posts ??= new List<Post>();
        posts.Insert(0, post);

        post = new Post();
        isSubmitting = false;
        statusMessage = "Post created!";
    }

}
