@page "/profile"
@using Microsoft.AspNetCore.Identity
@using glubhub.Data
@using glubhub.Models
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager

<style>
    .post_container {
        text-align: center;
    }

</style>
<MudCard>
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@userName</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Default" />
        </CardHeaderActions>
    </MudCardHeader>

    <MudCardContent>
        <MudText Typo="Typo.body2">Some short bio or description.</MudText>
    </MudCardContent>

    <MudCardActions>
        <MudButton Variant="Variant.Text" Color="Color.Primary">Edit profile</MudButton>
    </MudCardActions>
</MudCard>

<div class="post_container">
<h2 style="font-weight: bold;"> My posts</h2>

@if (posts == null)
{
    <p>Loading profile...</p>
}
else if (!posts.Any())
{
    <p>No posts yet.</p>
}
else
{
    <ul>
        @foreach (var post in posts)
        {
            <li>
                <h3>@post.Content</h3>
                <p>@post.Comment</p>
                <small>Posted on @post.Timestamp.ToString("g")</small>
                <small>Id: @post.PostId</small>
            </li>
        }
    </ul>
}
</div>

@code {
    private string? userName;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await 
        AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is { IsAuthenticated: true })
        {
            userName = user.Identity.Name ?? "Unknown User";
        }
        else
        {
            userName = "Guest";
        }
    }

    private List<Post>? posts;
   
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is { IsAuthenticated: true })
        {
            var userIdString = user.FindFirst(c => c.Type.Contains("nameidentifier"))?.Value;
            if (Guid.TryParse(userIdString, out var userId))
            {
                posts = Db.Posts
                    .Where(p => p.UserId == userId)
                    .OrderByDescending(p => p.Timestamp)
                    .ToList();
            }
            else
            {
                posts = new List<Post>();
            }
        }
        else
        {
            posts = new List<Post>();
        }
    }
}
