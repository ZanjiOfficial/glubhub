@using glubhub.Models;
@using System.Threading.Tasks;
@using static glubhub.Models.Weather

@page "/weather"
@inject WeatherService WeatherService
@rendermode InteractiveServer

<h3>Vejrudsigt</h3>

<input @bind="City" @bind:event="oninput" placeholder="Indtast en by..." />
<button type="button" class="btn btn-primary" @onclick="@OnInitializedAsync">Hent Vejrudsigt</button>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

@if (IsLoading)
{
    <p>Indlæser vejrudsigt…</p>
}

<h3 class="mt-5">Se vejrudsigten for de næste 5 dage</h3>

<div class="row row-cols-1 row-cols-md-5 g-4 mt-2">
    @if (!IsLoading && Forecast != null && Forecast.Any())
    {
        foreach (var day in Forecast)
        {
            <div class="col">
                <div class="card h-100 text-center shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@DateTime.Parse(day.Date).ToString("ddd, MMM d")</h5>
                        <img src="@day.IconUrl" alt="@day.IconPhrase" class="mb-2" />
                        <p class="card-text">@day.IconPhrase</p>
                        <p class="text-muted small">Min: @day.MinTemp</p>
                        <p class="text-muted small">Max: @day.MaxTemp</p>
                    </div>
                </div>
            </div>
        }
    }
    else if (!IsLoading && (Forecast == null || !Forecast.Any()))
    {
        <p>No forecast data available.</p>
    }
</div>

@code {
    [Parameter]
    public EventCallback OnWeatherLoaded { get; set; }


    private List<ForecastDay> Forecast = new();
    private string City = "Odense";
    private bool IsLoading = false;
    private string? ErrorMessage;

    private async Task LoadWeather()
    {
        IsLoading = true;
        ErrorMessage = null;
        var (forecast, error) = await WeatherService.GetForecastAsync(City);
        Forecast = forecast;
        ErrorMessage = error;
        IsLoading = false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadWeather();
        
    }
} 

