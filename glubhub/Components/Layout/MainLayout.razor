@* Required *@
@*https://stackoverflow.com/questions/78037070/mudblazor-toggle-dark-light-theme-from-appbar*@
<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />


@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />
@*https://www.youtube.com/watch?v=RmGh_tMIE0k&t=536s Shout out*@
@*https://www.youtube.com/watch?v=VaA_5BGyC6I Darkmode shout out*@
<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Transparent" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-2">Glub Hub</MudText>
        <MudSpacer />
        <MudToggleIconButton Icon="@Icons.Material.Filled.LightMode" Color="Color.Inherit"
        ToggledIcon="@Icons.Material.Filled.DarkMode" ToggledColor="Color.Default"
        Toggled="@_isDarkMode"
        ToggledChanged="ToggleDarkMode" />

    </MudAppBar>
        
    <MudDrawer @bind-Open="_drawerOpen"> 
        <NavMenu/>
    </MudDrawer>
    <MudMainContent Class="px-5 p-10" MaxWidth="MaxWidth.Medium" Style="background-color: var(--mud-palette-background-grey); min-height: 100vh;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private MudTheme _theme = new();


    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleDarkMode(bool mode)
    {
        _isDarkMode = mode;
        StateHasChanged();
    }


}